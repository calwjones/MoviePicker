generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")

  userMovies        UserMovie[]
  soloSessions      SwipeSession[]
  groupSessionsAsP2 SwipeSession[] @relation("SessionUser2")

  @@map("users")
}

model Movie {
  id                 String  @id @default(uuid())
  tmdbId             Int     @unique @map("tmdb_id")
  title              String
  year               Int?
  posterUrl          String? @map("poster_url")
  overview           String?
  genres             Json    @default("[]")
  director           String?
  cast               Json    @default("[]")
  runtime            Int?
  tmdbRating         Float?  @map("tmdb_rating")
  streamingProviders Json    @default("[]") @map("streaming_providers")

  userMovies    UserMovie[]
  sessionMovies SessionMovie[]
  matches       Match[]

  @@map("movies")
}

model UserMovie {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  movieId     String   @map("movie_id")
  source      String   @default("manual")
  onWatchlist Boolean  @default(false) @map("on_watchlist")
  watched     Boolean  @default(false)
  userRating  Float?   @map("user_rating")
  createdAt   DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  movie Movie @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId])
  @@map("user_movies")
}

model SwipeSession {
  id        String   @id @default(uuid())
  type      String   @default("group")
  userId    String?  @map("user_id")
  user2Id   String?  @map("user_2_id")
  guestId   String?  @map("guest_id")
  guestName String?  @map("guest_name")
  status    String   @default("waiting")
  filters   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user    User?          @relation(fields: [userId], references: [id])
  user2   User?          @relation("SessionUser2", fields: [user2Id], references: [id])
  movies  SessionMovie[]
  matches Match[]

  @@map("swipe_sessions")
}

model SessionMovie {
  id        String  @id @default(uuid())
  sessionId String  @map("session_id")
  movieId   String  @map("movie_id")
  user1Swipe String? @map("user_1_swipe")
  user2Swipe String? @map("user_2_swipe")

  session SwipeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  movie   Movie        @relation(fields: [movieId], references: [id])

  @@unique([sessionId, movieId])
  @@map("session_movies")
}

model Match {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  movieId     String   @map("movie_id")
  resolved    Boolean  @default(false)
  watched     Boolean  @default(false)
  watchedAt   DateTime? @map("watched_at")
  user1Rating Float?   @map("user_1_rating")
  user2Rating Float?   @map("user_2_rating")

  session SwipeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  movie   Movie        @relation(fields: [movieId], references: [id])

  @@unique([sessionId, movieId])
  @@map("matches")
}

